# Copy this file to .env and fill in real values. Never commit .env.

# --- Database (Neon Postgres) ---
# Neon provides two connection strings per branch:
#   1. Pooled (host contains "-pooler") — for the running app. High connection
#      concurrency via PgBouncer; required for serverless deployments.
#   2. Direct (no "-pooler") — for Prisma Migrate, which needs a direct
#      connection to run DDL. Never point the app itself at this.
# Find both in the Neon console: Project -> Dashboard -> Connection Details.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Auth (NextAuth / Auth.js v5) ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# Canonical URL of the app (http://localhost:3000 in development).
AUTH_URL="http://localhost:3000"

# --- Seed (initial admin account created by `npm run db:seed`) ---
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""

# --- Coming in later phases (documented now so nothing is hardcoded) ---
# Blob/image storage (Vercel Blob or Cloudinary or S3):
# BLOB_READ_WRITE_TOKEN=""
# Payments (Stripe):
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Transactional email (Resend):
# RESEND_API_KEY=""
# SMS (Twilio or local provider):
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
